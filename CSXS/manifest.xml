<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
  ExtensionBundleId="com.henrique.ironcomposer"
  ExtensionBundleVersion="2.0.0"
  ExtensionBundleName="IronComposer"
  Version="11.0">

  <ExtensionList>
    <Extension Id="com.henrique.ironcomposer.panel" Version="2.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere 2024 (v24) até versões futuras -->
      <Host Name="PPRO" Version="[24.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.henrique.ironcomposer.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
            <Parameter>--autoplay-policy=no-user-gesture-required</Parameter>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--disable-web-security</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>IronComposer</Menu>
          <Geometry>
            <Size>
              <Height>700</Height>
              <Width>420</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>320</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
